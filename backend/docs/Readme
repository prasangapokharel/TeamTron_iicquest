document: id, multipaths(in same row mutiple document)
signature: document_enroll_id, hash, txid
apikey:company_id, apikey , status(active, revoke)
plan: Peruser(int(Rs 100))
payment: comapany_id,plan_id,transaction_id(8combination),amount , date 


