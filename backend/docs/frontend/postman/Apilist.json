          "name": "Top Up Balance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/balance/topup", "host": ["{{base_url}}"], "path": ["api", "v1", "balance", "topup"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"amount\": 50\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payment Method",
      "item": [
        {
          "name": "List Payment Methods",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/v1/payment_method", "host": ["{{base_url}}"], "path": ["api", "v1", "payment_method"] }
          }
        }
      ]
    },
    {
      "name": "Transaction",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/transaction", "host": ["{{base_url}}"], "path": ["api", "v1", "transaction"] }
          }
        }
      ]
    },
    {
      "name": "Payment",
      "item": [
        {
          "name": "Create Payment (Plan)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/payment", "host": ["{{base_url}}"], "path": ["api", "v1", "payment"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"plan_id\": \"replace-with-plan-id\",\n  \"amount\": 999\n}"
            }
          }
        },
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/payment", "host": ["{{base_url}}"], "path": ["api", "v1", "payment"] }
          }
        },
        {
          "name": "eSewa — Initialize",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/payment/initialize", "host": ["{{base_url}}"], "path": ["api", "v1", "payment", "initialize"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"amount\": 100\n}"
            },
            "description": "Returns eSewa form fields. Frontend submits these as a form POST to esewa_url. Each credit = NPR 1."
          }
        },
        {
          "name": "eSewa — Success Callback (backend auto-handles)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/payment/success?data=base64encodedPayload",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment", "success"],
              "query": [{ "key": "data", "value": "base64encodedPayload", "description": "eSewa sends this automatically — do not call manually" }]
            },
            "description": "eSewa redirects here automatically after successful payment. Verifies with eSewa API, adds credits to balance, records transaction."
          }
        },
        {
          "name": "eSewa — Failure Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/v1/payment/failure", "host": ["{{base_url}}"], "path": ["api", "v1", "payment", "failure"] },
            "description": "eSewa redirects here on failure or cancellation."
          }
        }
      ]
    },
    {
      "name": "Verify",
      "item": [
        {
          "name": "Verify (JSON paths)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "JWT auth — use this OR X-Api-Key, not both" },
              { "key": "X-Api-Key", "value": "{{api_key}}", "disabled": true, "description": "API key auth — enable this and disable Authorization header for server-to-server calls" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/verify", "host": ["{{base_url}}"], "path": ["api", "v1", "verify"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"paths\": [\n    \"uploads/company-id/doc1.jpg\",\n    \"uploads/company-id/doc2.jpg\"\n  ],\n  \"criteria_id\": \"replace-with-criteria-id\"\n}"
            }
          }
        },
        {
          "name": "Verify Upload",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "JWT auth — use this OR X-Api-Key, not both" },
              { "key": "X-Api-Key", "value": "{{api_key}}", "disabled": true, "description": "API key auth — enable this and disable Authorization header for server-to-server calls" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/verify/upload", "host": ["{{base_url}}"], "path": ["api", "v1", "verify", "upload"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "criteria_id", "value": "replace-with-criteria-id", "type": "text" },
                { "key": "files", "type": "file", "src": "/path/to/doc1.jpg" },
                { "key": "files", "type": "file", "src": "/path/to/doc2.jpg" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Assistant",
      "item": [
        {
          "name": "Chat",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "Use JWT or omit if using X-API-Key" },
              { "key": "X-API-Key", "value": "replace-with-api-key", "disabled": true, "description": "Alternative to Bearer token" },
