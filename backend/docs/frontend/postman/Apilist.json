        {
          "name": "List Plans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/plan", "host": ["{{base_url}}"], "path": ["api", "v1", "plan"] }
          }
        }
      ]
    },
    {
      "name": "Balance",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/balance", "host": ["{{base_url}}"], "path": ["api", "v1", "balance"] }
          }
