            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"category_id\": \"replace-with-category-id\"\n}"
            }
          }
        },
        {
          "name": "Get Enrolled",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/category/enrolled", "host": ["{{base_url}}"], "path": ["api", "v1", "category", "enrolled"] }
          }
        }
      ]
    },
    {
      "name": "Criteria",
      "item": [
        {
          "name": "List Criteria",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/criteria", "host": ["{{base_url}}"], "path": ["api", "v1", "criteria"] }
          }
        },
        {
          "name": "Create Criteria",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/criteria", "host": ["{{base_url}}"], "path": ["api", "v1", "criteria"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"data\": {\n    \"name\": \"Passport KYC\",\n    \"category\": \"Identity\",\n    \"fields\": [\"full_name\", \"dob\", \"passport_number\", \"expiry_date\"],\n    \"rules\": [\n      { \"field\": \"full_name\", \"match\": \"cross_doc\", \"severity\": \"high\" },\n      { \"field\": \"dob\", \"match\": \"cross_doc\", \"severity\": \"high\" }\n    ]\n  }\n}"
            }
          }
        },
        {
          "name": "Enroll Criteria",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/criteria/enroll", "host": ["{{base_url}}"], "path": ["api", "v1", "criteria", "enroll"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"criteria_id\": \"replace-with-criteria-id\",\n  \"severity\": \"high\",\n  \"message\": \"Critical KYC check\",\n  \"is_critical\": true\n}"
            }
          }
        },
        {
          "name": "Get Enrolled",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/criteria/enrolled", "host": ["{{base_url}}"], "path": ["api", "v1", "criteria", "enrolled"] }
          }
        }
      ]
    },
    {
      "name": "Document",
      "item": [
        {
          "name": "Create Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/document", "host": ["{{base_url}}"], "path": ["api", "v1", "document"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"paths\": [\n    \"uploads/company-id/file1.jpg\",\n    \"uploads/company-id/file2.jpg\"\n  ]\n}"
            }
          }
        },
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/document", "host": ["{{base_url}}"], "path": ["api", "v1", "document"] }
          }
        },
        {
          "name": "Get Document",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/document/:enroll_id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "document", ":enroll_id"],
              "variable": [{ "key": "enroll_id", "value": "replace-with-enroll-id" }]
            }
          }
        },
        {
          "name": "Get Result",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/document/:enroll_id/result",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "document", ":enroll_id", "result"],
              "variable": [{ "key": "enroll_id", "value": "replace-with-enroll-id" }]
            }
          }
        },
        {
          "name": "Verify (Upload)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/document/verify", "host": ["{{base_url}}"], "path": ["api", "v1", "document", "verify"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "criteria_id", "value": "replace-with-criteria-id", "type": "text" },
                { "key": "files", "type": "file", "src": "/path/to/doc1.jpg" },
                { "key": "files", "type": "file", "src": "/path/to/doc2.jpg" }
              ]
            }
          }
        },
        {
          "name": "Spoofing Verify",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "description": "JWT auth — use this OR X-Api-Key, not both" },
              { "key": "X-Api-Key", "value": "{{api_key}}", "disabled": true, "description": "API key auth — enable this and disable Authorization header for server-to-server calls" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/document/spoofing/verify", "host": ["{{base_url}}"], "path": ["api", "v1", "document", "spoofing", "verify"] },
            "description": "Compare Image A vs Image B to detect spoofing. Image A is the claimed verified document; Image B is the document being presented. Returns metadata (hash, dimensions, phash), comparison verdict (IDENTICAL/SIMILAR/DIFFERENT), and spoofing_detected when Image A was previously verified but Image B differs.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file_a", "type": "file", "src": "/path/to/verified-document.png", "description": "Claimed verified document (Image A)" },
                { "key": "file_b", "type": "file", "src": "/path/to/presented-document.png", "description": "Document being presented (Image B)" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Signature",
      "item": [
        {
          "name": "List Signatures",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/signature", "host": ["{{base_url}}"], "path": ["api", "v1", "signature"] }
          }
        },
        {
          "name": "Get Signature",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/signature/:document_enroll_id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "signature", ":document_enroll_id"],
              "variable": [{ "key": "document_enroll_id", "value": "replace-with-enroll-id" }]
            }
          }
        },
        {
          "name": "Verify TXID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/signature/verify/:txid",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "signature", "verify", ":txid"],
              "variable": [{ "key": "txid", "value": "replace-with-txid" }]
            }
          }
        },
        {
          "name": "Sign Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/signature", "host": ["{{base_url}}"], "path": ["api", "v1", "signature"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"document_enroll_id\": \"replace-with-enroll-id\",\n  \"fields\": {\n    \"full_name\": \"John Doe\",\n    \"dob\": \"1990-01-01\",\n    \"passport_number\": \"A1234567\"\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Plan",
