          }
        },
        {
          "name": "List Keys",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/apikey", "host": ["{{base_url}}"], "path": ["api", "v1", "apikey"] }
          }
        },
        {
          "name": "Revoke Key",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/apikey/:apikey_id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "apikey", ":apikey_id"],
              "variable": [{ "key": "apikey_id", "value": "replace-with-apikey-id" }]
            }
          }
        }
      ]
    },
